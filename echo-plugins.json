      "version": "1.0.0",
      "description": "自定义无封面或封面加载失败时的显示内容，支持文字渲染和自定义图片。",
      "author": "EchoMusic",
      "icon": "icon.svg",
      "path": "cover-fallback",
      "repo": "https://github.com/hoowhoami/EchoMusicPlugins/tree/main/cover-fallback",
      "homepage": "https://github.com/hoowhoami/EchoMusicPlugins/tree/main/cover-fallback",
      "tags": ["appearance", "cover", "mini-player"],
      "requires": {
        "echoMusicVersion": ">=2.2.6-beta.9"
      }
    },
    {
      "id": "lyric-info-scroll",
      "name": "信息区歌词滚动",
      "version": "1.0.0",
      "description": "用当前歌词替换主播放器和 mini 播放器的歌曲信息展示。",
      "author": "EchoMusic",
      "icon": "icon.svg",
      "path": "lyric-info-scroll",
      "repo": "https://github.com/hoowhoami/EchoMusicPlugins/tree/main/lyric-info-scroll",
      "homepage": "https://github.com/hoowhoami/EchoMusicPlugins/tree/main/lyric-info-scroll",
      "tags": ["lyrics", "player-bar", "mini-player"],
      "requires": {
        "echoMusicVersion": ">=2.2.6-beta.9"
      }
    },
    {
      "id": "spectrum-visualizer",
      "name": "频谱可视化",
      "version": "1.0.0",
      "description": "在播放栏、mini 播放器和歌词页底部控制区显示跟随音频变化的频谱背景。",
      "author": "EchoMusic",
      "icon": "icon.svg",
      "path": "spectrum-visualizer",
      "repo": "https://github.com/hoowhoami/EchoMusicPlugins/tree/main/spectrum-visualizer",
      "homepage": "https://github.com/hoowhoami/EchoMusicPlugins/tree/main/spectrum-visualizer",
      "tags": ["audio", "spectrum", "player-bar", "mini-player", "lyrics"],
      "requires": {
        "echoMusicVersion": ">=2.2.6-beta.10"
      }
